Content-Type: application/json

{
  "name": "Stefan",
  "email": "stefan@gmail.com",
  "password": "123456"
}

###

### Update user
PUT {{WebApplication2_HostAddress}}/api/users/6
Content-Type: application/json

{
  "name": "Davor Updated",
  "email": "davor.updated@gmail.com"
 
}

###

### Delete user
DELETE {{WebApplication2_HostAddress}}/api/users/5

###

### Get all users after delete
GET {{WebApplication2_HostAddress}}/api/users
Accept: application/json



